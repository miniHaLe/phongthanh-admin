# Frontend (Vite) — copy to .env.local for dev.
# Which resources hit the real API vs the in-memory mock (comma-separated resourceKeys).
# Dev/CI ONLY — the prod build guard fails unless this covers every v1 resource.
VITE_REAL_RESOURCES=khach-hang,nguoi-dung,nhom-quyen,chi-nhanh,don-vi-tinh,nhom-san-pham,nhom-hang-hoa,nha-san-xuat,thoi-han,nha-kho,phuong-xa,khu-vuc,loi-sua-chua,ngan-chua,san-pham,hang-hoa,model,phi-giao,ngan-hang,dia-ly
# Base URL of the NestJS API (must match api/.env PORT — default 3210).
VITE_API_URL=http://localhost:3210
