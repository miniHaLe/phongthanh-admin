{
  "name": "phongthanh-admin",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:prod": "node scripts/assert-real-resources.mjs --prod && tsc -b && vite build",
    "preview": "vite preview",
    "lint": "oxlint",
    "test": "vitest run",
    "test:api": "cd api && npm test",
    "test:api:with-db": "bash scripts/test-api-with-db.sh",
    "test:e2e:uiux": "playwright test -c playwright.config.ts",
    "test:e2e:uiux:headed": "playwright test -c playwright.config.ts --headed",
    "data:generate:vn-admin": "node scripts/generate-vietnam-administrative-snapshot.mjs",
    "test:watch": "vitest",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\"",
    "type-check": "tsc -b"
  },
  "dependencies": {
