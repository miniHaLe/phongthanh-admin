# Copy to api/.env for local dev. NEVER commit the real .env (gitignored).

# Postgres connection. Matches the root docker-compose.yml service (host 5434).
DATABASE_URL=postgres://phongthanh:phongthanh_dev@localhost:5434/phongthanh

# JWT signing secrets — must be >= 16 chars. Use long random values in prod.
JWT_SECRET=dev-access-secret-change-me-please-1234567890
JWT_REFRESH_SECRET=dev-refresh-secret-change-me-please-0987654321

# Super-admin bootstrap password (V4). The seeder hashes this for every seeded
# user; each is forced to change it on first login (must_change_password).
INITIAL_ADMIN_PASSWORD=change-me-on-first-login

# API port. 3000 is often taken locally; 3210 keeps this project conflict-free.
# The frontend's VITE_API_URL must match.
PORT=3210

# CORS origin for the Vite dev server. Use comma-separated origins when the same
# API also serves a hosted frontend, e.g. http://localhost:5173,https://app.example.com
CORS_ORIGIN=http://localhost:5173

# Optional comma-separated origins appended to CORS_ORIGIN. Render Blueprint uses
# this to inject the actual static frontend URL assigned by Render.
CORS_ADDITIONAL_ORIGINS=

# Public API hardening. Render runs behind one trusted proxy hop.
TRUST_PROXY_HOPS=1
AUTH_LOGIN_RATE_LIMIT_MAX=20
AUTH_LOGIN_RATE_LIMIT_WINDOW_MS=900000
AUTH_REFRESH_RATE_LIMIT_MAX=120
AUTH_REFRESH_RATE_LIMIT_WINDOW_MS=60000
API_RATE_LIMIT_MAX=600
API_RATE_LIMIT_WINDOW_MS=60000

# Keep "strict" for same-site local/dev. Use "none" when the hosted frontend and
# API are on different sites, e.g. GitHub Pages -> Render.
REFRESH_COOKIE_SAME_SITE=strict
