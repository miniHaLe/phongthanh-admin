# Copy to .env.docker for the local full-stack Docker flow:
#   cp .env.docker.example .env.docker   (then edit for anything real)
# scripts/docker-run.sh loads this via `docker compose --env-file`.
# .env.docker is gitignored — NEVER commit real secrets.
#
# For a real deploy, export these in the host environment / secret manager
# instead of using this file, and use strong random values (>= 32 chars).

